"/><column index="3" value="75"/><column index="4" value="83"/><column index="5" value="104"/><column index="6" value="67"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="egg_production" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="37"/><column index="2" value="106"/><column index="3" value="75"/><column index="4" value="83"/><column index="5" value="104"/><column index="6" value="89"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="honey_production" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="37"/><column index="2" value="75"/><column index="3" value="83"/><column index="4" value="104"/><column index="5" value="68"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="milk_production" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="37"/><column index="2" value="50"/><column index="3" value="75"/><column index="4" value="83"/><column index="5" value="104"/><column index="6" value="57"/><column index="7" value="89"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="state_lookup" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="170"/><column index="2" value="83"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="yogurt_production" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="37"/><column index="2" value="50"/><column index="3" value="75"/><column index="4" value="83"/><column index="5" value="104"/><column index="6" value="57"/><column index="7" value="74"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- Average coffee production for years where honey &gt; 1,000,000
WITH honey_by_year AS (
  SELECT
    Year,
    SUM(CAST(Value AS INTEGER)) AS honey_sum
  FROM honey_production
  WHERE Value IS NOT NULL
    -- AND Period = 'ANNUAL'      -- include if your table has Period
    -- AND Geo_Level = 'STATE'     -- include if present
  GROUP BY Year
),
coffee_by_year AS (
  SELECT
    Year,
    SUM(CAST(Value AS INTEGER)) AS coffee_sum
  FROM coffee_production
  WHERE Value IS NOT NULL
    -- AND Period = 'ANNUAL'
    -- AND Geo_Level = 'STATE'
  GROUP BY Year
)
SELECT
  AVG(coffee_sum * 1.0) AS avg_coffee_for_honey_gt_1m
FROM coffee_by_year
WHERE Year IN (
  SELECT Year FROM honey_by_year WHERE honey_sum &gt; 1000000
);
</sql><current_tab id="0"/></tab_sql></sqlb_project>
